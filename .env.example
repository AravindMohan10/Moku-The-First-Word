# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# HF_TOKEN must be a fine-grained token with:
#   "Make calls to Inference Providers" enabled
# Create at: https://huggingface.co/settings/tokens

HF_TOKEN=
MEM0_API_KEY=
MOKU_HF_MODEL=openbmb/MiniCPM5-1B
MOKU_LLM_PROVIDER=auto
MOKU_MAX_TOKENS=420
MOKU_TEMPERATURE=0.65
MOKU_LLM_TIMEOUT=25
MOKU_JSON_MODE=1
MOKU_TICK_SECONDS=2.5
MOKU_MEMORY_DB=data/moku_memories.sqlite3
