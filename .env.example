# Copy to .env and fill in your keys:
#   cp .env.example .env
#
# HF_TOKEN must be a fine-grained token with:
#   "Make calls to Inference Providers" enabled
# Create at: https://huggingface.co/settings/tokens
#
# OpenBMB models are NOT on HF Inference Providers — serve via Modal vLLM (see modal/moku_modal.py)
# or local llama.cpp/vLLM, then point MOKU_MODEL_BASE_URL at that endpoint.

HF_TOKEN=
MEM0_API_KEY=

# Mem0 retrieval quota saver: local reads from SQLite mirror (same memories, zero search API calls).
# Writes still go to Mem0 when MEM0_API_KEY is set. Use for dev + hackathon demo.
# Values: auto (default) | local | platform
MOKU_MEM0_RETRIEVE=local

# Primary model — OpenBMB MiniCPM3-4B (≤4B, best JSON/agent quality in the OpenBMB family)
MOKU_HF_MODEL=openbmb/MiniCPM3-4B
# HF dev fallback only (OpenBMB not on Inference Providers for most accounts):
MOKU_HF_MODEL_FALLBACKS=Qwen/Qwen2.5-Coder-3B-Instruct,deepseek-ai/DeepSeek-R1-Distill-Qwen-1.5B

# auto = local Modal/vLLM first when MOKU_MODEL_BASE_URL is set, else HF + fallbacks
MOKU_LLM_PROVIDER=auto

# Modal vLLM (recommended for judge demo + OpenBMB Awards):
#   modal deploy modal/moku_modal.py
#   MOKU_MODEL_BASE_URL=https://<your-workspace>--moku-the-first-word-serve.modal.run/v1
MOKU_MODEL_BASE_URL=https://m-aravind619--moku-the-first-word-serve.modal.run/v1
MOKU_MODEL_API_KEY=local

MOKU_MAX_TOKENS=220
MOKU_TEMPERATURE=0.65
MOKU_LLM_TIMEOUT=90
MOKU_JSON_MODE=1
MOKU_LOCAL_JSON_MODE=0
MOKU_PREFETCH_MINDS=1
MOKU_MEMORY_RETRIEVE_K=5
MOKU_TICK_SECONDS=3.5
MOKU_MEMORY_DB=data/moku_memories.sqlite3
